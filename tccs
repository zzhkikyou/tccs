#!/usr/bin/env python3
"""Tiny Claude Code Switch: manage LLM provider profiles via env vars."""

import argparse
import json
import os
import re
import shlex
import sys
from pathlib import Path
from typing import Dict, List, Optional

TCCS_DIR_NAME = ".tccs"
ACTIVE_LINK_NAME = "llm.json"
PROFILE_PREFIX = "llm_"
PROFILE_SUFFIX = ".json"
PROFILE_NAME_RE = re.compile(r"^[A-Za-z0-9_-]+$")

SHELL_FILES = (".bashrc", ".bash_profile", ".zshrc")

INIT_MARKER_START = "# >>> tccs initialized >>>"
INIT_MARKER_END = "# <<< tccs initialized <<<"

INIT_FUNCTION = """{start}
tccs-switch() {{
    eval "$(tccs -s \"$1\")"
}}
tccs-refresh() {{
    eval "$(tccs -e)"
}}

# Auto-activate current tccs profile
if declare -f tccs-refresh &>/dev/null; then
    tccs-refresh
fi
{end}
""".format(start=INIT_MARKER_START, end=INIT_MARKER_END)


def tccs_dir() -> Path:
    return Path.home() / TCCS_DIR_NAME


def active_link() -> Path:
    return tccs_dir() / ACTIVE_LINK_NAME


def ensure_tccs_dir() -> None:
    d = tccs_dir()
    if not d.exists():
        d.mkdir(mode=0o700)
    else:
        d.chmod(0o700)


def profile_path(name: str) -> Path:
    return tccs_dir() / "{}{}{}".format(PROFILE_PREFIX, name, PROFILE_SUFFIX)


def list_profiles() -> List[str]:
    d = tccs_dir()
    if not d.exists():
        return []
    profiles = []
    for f in d.iterdir():
        if f.is_file() and f.name.startswith(PROFILE_PREFIX) and f.name.endswith(PROFILE_SUFFIX):
            name = f.name[len(PROFILE_PREFIX):-len(PROFILE_SUFFIX)]
            profiles.append(name)
    return sorted(profiles)


def get_active_profile() -> Optional[str]:
    link = active_link()
    if not link.is_symlink():
        return None
    target_name = os.readlink(str(link))
    name = os.path.basename(target_name)
    if name.startswith(PROFILE_PREFIX) and name.endswith(PROFILE_SUFFIX):
        return name[len(PROFILE_PREFIX):-len(PROFILE_SUFFIX)]
    return None


def load_profile(name: str) -> Dict[str, str]:
    p = profile_path(name)
    with open(p, "r", encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict):
        raise ValueError("Profile {}: expected JSON object".format(name))
    for k, v in data.items():
        if not isinstance(v, str):
            raise ValueError("Profile {}: all values must be strings".format(name))
    return {str(k): v for k, v in data.items()}


def print_exports(data: Dict[str, str]) -> None:
    for key, value in data.items():
        print('export {}={}'.format(key, shlex.quote(value)))


def shell_config_candidates() -> List[Path]:
    home = Path.home()
    return [home / f for f in SHELL_FILES]


def find_initialized_shell_config() -> Optional[Path]:
    for p in shell_config_candidates():
        if p.exists() and INIT_MARKER_START in p.read_text(encoding="utf-8"):
            return p
    return None


def cmd_init(force: bool = False) -> int:
    existing = find_initialized_shell_config()
    if existing is not None and not force:
        print("tccs-switch already exists in {}, no need to reinitialize.".format(existing))
        print("Use tccs --reinit to force reinitialization.")
        return 0

    candidates = shell_config_candidates()
    existing_files = [p for p in candidates if p.exists()]
    target = existing_files[0] if existing_files else candidates[0]

    content = target.read_text(encoding="utf-8") if target.exists() else ""
    # If old init block exists, remove it first
    if INIT_MARKER_START in content and force:
        content = re.sub(
            r"\n?" + re.escape(INIT_MARKER_START) + r".*?" + re.escape(INIT_MARKER_END),
            "",
            content,
            flags=re.DOTALL,
        )
        print("Removed old tccs init block.", file=sys.stderr)
    if content and not content.endswith("\n"):
        content += "\n"
    content += "\n" + INIT_FUNCTION + "\n"
    target.write_text(content, encoding="utf-8")
    print("Written to {}. Please run:".format(target))
    print("    source {}".format(target))
    print("After that, you can use tccs-switch <profile>.")
    print("tccs-refresh and auto-activation configured; current profile will be auto-applied on bash start.")
    return 0


def print_create_hint() -> None:
    print(
        "Hint: create JSON files under {} as profiles, e.g. {}.".format(
            tccs_dir(), profile_path("example").name
        ),
        file=sys.stderr,
    )


def print_no_profile_hint() -> None:
    active = get_active_profile()
    profiles = list_profiles()
    if active is None and not profiles:
        print_create_hint()
    elif active is None:
        print(
            "Hint: use tccs -s <name> to activate a profile. Available profiles: {}".format(
                ", ".join(profiles)
            ),
            file=sys.stderr,
        )
    else:
        # active is set but profile file is missing
        print_create_hint()


def cmd_list() -> int:
    active = get_active_profile()
    if active is None:
        print("No active profile.")
        print_no_profile_hint()
        return 0
    target = profile_path(active)
    if not target.exists():
        print("Active profile file not found: {}".format(active), file=sys.stderr)
        print_create_hint()
        return 1
    print("Active profile: {}".format(active))
    data = load_profile(active)
    for key in sorted(data.keys()):
        print("  {}={}".format(key, data[key]))
    return 0


def cmd_list_all() -> int:
    active = get_active_profile()
    profiles = list_profiles()
    if not profiles:
        print("No profiles found.")
        print_create_hint()
        return 0
    for name in profiles:
        marker = "* " if name == active else "  "
        print("{}{}".format(marker, name))
    return 0


def cmd_switch(name: str) -> int:
    if not PROFILE_NAME_RE.fullmatch(name):
        print("Invalid profile name: {}".format(name), file=sys.stderr)
        return 1
    target = profile_path(name)
    if not target.exists():
        print("Profile not found: {}".format(name), file=sys.stderr)
        profiles = list_profiles()
        if profiles:
            print("Available profiles: {}".format(", ".join(profiles)), file=sys.stderr)
        else:
            print_create_hint()
        return 1
    link = active_link()
    if link.exists() or link.is_symlink():
        link.unlink()
    link.symlink_to(target.name)
    data = load_profile(name)
    print_exports(data)
    return 0


def cmd_delete(name: str) -> int:
    if not PROFILE_NAME_RE.fullmatch(name):
        print("Invalid profile name: {}".format(name), file=sys.stderr)
        return 1
    target = profile_path(name)
    if not target.exists():
        print("Profile not found: {}".format(name), file=sys.stderr)
        profiles = list_profiles()
        if profiles:
            print("Available profiles: {}".format(", ".join(profiles)), file=sys.stderr)
        else:
            print_create_hint()
        return 1
    # If deleting the active profile, clean up the symlink too
    active = get_active_profile()
    if active == name:
        link = active_link()
        if link.is_symlink():
            link.unlink()
        print("Deactivated.", file=sys.stderr)
    target.unlink()
    print("Deleted profile: {}".format(name))
    return 0


def cmd_export() -> int:
    active = get_active_profile()
    if active is None:
        print("No active profile.", file=sys.stderr)
        print_no_profile_hint()
        return 1
    target = profile_path(active)
    if not target.exists():
        print("Active profile file not found: {}".format(active), file=sys.stderr)
        return 1
    data = load_profile(active)
    print_exports(data)
    if sys.stdout.isatty():
        print("", file=sys.stderr)
        print("Hint: run the following to apply environment variables immediately:", file=sys.stderr)
        print("    eval \"$(tccs -e)\"", file=sys.stderr)
        print("If already initialized, you can also run:", file=sys.stderr)
        print("    tccs-refresh", file=sys.stderr)
    return 0


EPILOG = """\
Usage:
  Add profile       Create a JSON file under {dir}, e.g. {example}.
                    File content as flat key-value pairs: {{"KEY": "value", ...}}
  Delete profile    tccs -d <name>
  List profiles     tccs -a
  Switch profile    tccs -s <name>          (or eval "$(tccs -s <name>)" to apply immediately)
  Show current      tccs -l
  Export env vars   tccs -e                 (or eval "$(tccs -e)")
  Init shell        tccs                   (first-time setup)
  Reinitialize      tccs --reinit          (update shell functions or fix issues)""".format(
    dir=tccs_dir(), example=profile_path("example").name
)


def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(
        prog="tccs",
        description="Tiny Claude Code Switch: manage LLM provider profiles.",
        epilog=EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("-l", action="store_true", help="Show active profile")
    parser.add_argument("-a", action="store_true", help="List all profiles")
    parser.add_argument("-s", metavar="NAME", help="Switch to profile and output export statements")
    parser.add_argument("-d", metavar="NAME", help="Delete a profile")
    parser.add_argument("-e", "--export", action="store_true", help="Output export statements for active profile")
    parser.add_argument("--reinit", action="store_true", help="Force reinitialize shell integration")

    args = parser.parse_args(argv)

    if args.reinit:
        return cmd_init(force=True)

    if not (args.l or args.a or args.s is not None or args.d is not None or args.export):
        return cmd_init()

    ensure_tccs_dir()

    try:
        if args.l:
            return cmd_list()
        if args.a:
            return cmd_list_all()
        if args.s is not None:
            return cmd_switch(args.s)
        if args.d is not None:
            return cmd_delete(args.d)
        if args.export:
            return cmd_export()
    except (ValueError, FileNotFoundError) as e:
        print("Error: {}".format(e), file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())

